{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)",       "destination": "/index.html"  }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff"       },
        { "key": "X-Frame-Options",         "value": "DENY"          },
        { "key": "Referrer-Policy",         "value": "no-referrer"   }
      ]
    }
  ],
  "functions": {
    "api/**/*.js": { "maxDuration": 30 }
  }
}
